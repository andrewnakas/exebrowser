# Cloudflare Pages headers.
#
# IMPORTANT: Cloudflare Pages MERGES headers from every matching rule.
# Emitting Cross-Origin-Embedder-Policy more than once causes Chrome to
# treat the policy as "unsafe-none" and disables SharedArrayBuffer.
# Therefore: COOP/COEP/CORP live ONLY in the catch-all /* rule below.
# Specific-path rules carry only non-overlapping headers (Cache-Control,
# Content-Type, etc.).

/app.js
  Cache-Control: public, max-age=60, must-revalidate

/style.css
  Cache-Control: public, max-age=60, must-revalidate

/index.html
  Cache-Control: public, max-age=60, must-revalidate

/
  Cache-Control: public, max-age=60, must-revalidate

/*.wasm
  Content-Type: application/wasm
  Cache-Control: public, max-age=31536000, immutable

/boxedwine/build/default/*
  Cache-Control: public, max-age=31536000, immutable

/boxedwine/build/18r2/*
  Cache-Control: public, max-age=31536000, immutable

# 64-bit (Boxedwine64 / wine64) experimental runtime + split rootfs parts.
# Immutable: the wasm/js and the rootfs .partNNN pieces never change in place
# (a new build ships new filenames). Same-origin, so COEP require-corp from the
# catch-all /* rule is satisfied without a CORP header.
/64/*.part*
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/octet-stream

/64/*.zip
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/zip

/64/boxedwine64.wasm
  Cache-Control: public, max-age=31536000, immutable

/64/boxedwine64.js
  Cache-Control: public, max-age=31536000, immutable

# Proxied via Pages Function (functions/api/fs/[file].js) → Worker.
/api/fs/*
  Cache-Control: public, max-age=3600
  Content-Type: application/zip

/boxedwine/apps/*
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/zip

# Catch-all. Single source of truth for cross-origin isolation headers.
/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Cross-Origin-Resource-Policy: same-origin
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# Open Cadet: this game uses NO SharedArrayBuffer / threads, so it does NOT need
# cross-origin isolation. The catch-all /* sets COOP: same-origin, which severs
# the parent<->iframe relationship and blocks the game from loading in its embed
# (blank frame). Relax COOP to unsafe-none on BOTH the play page and the bundle
# so the iframe embed works.
/run/space-cadet-open/*
  Cross-Origin-Opener-Policy: unsafe-none

# Bundle — always revalidate so updates show immediately, and relaxed COOP.
/apps/space-cadet/*
  Cache-Control: no-cache, must-revalidate
  Cross-Origin-Opener-Policy: unsafe-none
