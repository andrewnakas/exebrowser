# Cloudflare Pages headers.
#
# IMPORTANT: Cloudflare Pages MERGES headers from every matching rule.
# Emitting Cross-Origin-Embedder-Policy more than once causes Chrome to
# treat the policy as "unsafe-none" and disables SharedArrayBuffer.
# Therefore: COOP/COEP/CORP live ONLY in the catch-all /* rule below.
# Specific-path rules carry only non-overlapping headers (Cache-Control,
# Content-Type, etc.).

/app.js
  Cache-Control: public, max-age=60, must-revalidate

/style.css
  Cache-Control: public, max-age=60, must-revalidate

/index.html
  Cache-Control: public, max-age=60, must-revalidate

/
  Cache-Control: public, max-age=60, must-revalidate

/*.wasm
  Content-Type: application/wasm
  Cache-Control: public, max-age=31536000, immutable

/boxedwine/build/default/*
  Cache-Control: public, max-age=31536000, immutable

/boxedwine/build/18r2/*
  Cache-Control: public, max-age=31536000, immutable

# Proxied via Pages Function (functions/api/fs/[file].js) → Worker.
/api/fs/*
  Cache-Control: public, max-age=3600
  Content-Type: application/zip

/boxedwine/apps/*
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/zip

# Catch-all. Single source of truth for cross-origin isolation headers.
/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Cross-Origin-Resource-Policy: same-origin
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
